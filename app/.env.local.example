# Database (Supabase)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:5432/postgres"

# Auth.js
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=

# Bypasses auth so the app is testable without Google OAuth.
# Works on Vercel Preview deployments (VERCEL_ENV=preview) and in local dev (VERCEL_ENV unset).
# WARNING: also bypasses auth in local dev — don't leave set between sessions.
# WARNING: all routes are open when set, including any future admin-only pages — use for preview/testing only.
# Never set in Production — the VERCEL_ENV guard makes it structurally inert there, but don't set it anyway.
# PREVIEW_BYPASS_AUTH=true
