# Database (Supabase)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:5432/postgres"

# Auth.js
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=

# Preview deployments only — bypasses auth so the app is testable without Google OAuth.
# Set to "true" in Vercel's Preview environment. Never set in Production.
# PREVIEW_BYPASS_AUTH=true
